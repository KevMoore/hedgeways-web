# Online multiplayer: where the browser client connects.
#   - Production builds use .env.production (committed) → live Render server.
#   - For local dev, create .env.local (gitignored) to override, e.g. a local
#     authority started with `pnpm dev:server`:
#       VITE_WS_URL=ws://localhost:8787
#   - If unset entirely, the client falls back to ws://localhost:8787.
VITE_WS_URL=wss://hedgeways-server.onrender.com
