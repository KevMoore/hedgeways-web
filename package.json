{
  "name": "hedgeways",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json",
    "server": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "dev:server": "tsx watch server/index.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "deploy": "pnpm build && cp dist/index.html dist/200.html && surge ./dist hedgeways.surge.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "tsx": "^4.22.4",
    "ws": "^8.21.0"
  }
}
